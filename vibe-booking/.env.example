# LLM Provider — NVIDIA NIM (OpenAI-compatible)
NVIDIA_API_KEY=
MODEL_LLM=openai/gpt-oss-120b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# NestJS backend base URL
BACKEND_URL=http://localhost:3001

# 32+ character service key for backend auth (X-Service-Key header)
AI_SERVICE_KEY=

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# JWT secret for WebSocket auth (same as backend JWT_ACCESS_SECRET)
JWT_SECRET=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional: Sentry error tracking
SENTRY_DSN=
