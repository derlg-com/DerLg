# LLM Provider: "nvidia" (default) or "ollama"
MODEL_BACKEND=nvidia

# NVIDIA NIM API key (required when MODEL_BACKEND=nvidia)
NVIDIA_API_KEY=

# Ollama server URL (required when MODEL_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# NestJS backend base URL
BACKEND_URL=http://localhost:3001

# 32+ character service key for backend auth
AI_SERVICE_KEY=

# Redis connection string (Upstash or local)
REDIS_URL=redis://localhost:6379

# Optional
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
SENTRY_DSN=
