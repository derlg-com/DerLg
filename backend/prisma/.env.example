# Prisma — Supabase PostgreSQL Connection
# =============================================================================
# Two URLs are REQUIRED for Prisma + Supabase:
#
#   1. DATABASE_URL  → pooled connection (PgBouncer, port 6543)
#      Used by: Prisma Client at runtime, prisma studio
#      Must include ?pgbouncer=true so Prisma knows not to use prepared statements
#
#   2. DIRECT_URL    → direct connection (port 5432)
#      Used by: prisma migrate dev, prisma migrate deploy
#      Prisma Migrate requires a direct session-level connection
#
# Shadow DB is NOT needed — we use `prisma migrate dev --create-only` + manual apply
# or run migrations locally. For Supabase, prefer `prisma migrate deploy` in CI.
# =============================================================================

# Pooled — runtime queries (PgBouncer)
DATABASE_URL=

# Direct — migrations only (no PgBouncer)
DIRECT_URL=

# Seed
AUTO_SEED=true