# =============================================================================
# DerLg Backend — Environment Variables
# =============================================================================
# Copy this file to .env (dev) or .env.production (prod) and fill in values.
# Never commit real secrets.
#
# Development: Uses Supabase for PostgreSQL, Docker for Redis/MinIO.
# Production: Uses Docker for PostgreSQL, Redis, and MinIO.
# =============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PORT=5001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---------------------------------------------------------------------------
# Database (Supabase in Development)
# ---------------------------------------------------------------------------
# Development (Supabase):
#   DATABASE_URL → Supabase connection pooler (PgBouncer, port 6543)
#   DIRECT_URL   → Supabase direct connection (port 5432, for migrations only)
#
# Production (Docker):
#   DATABASE_URL → Direct postgres connection
#   DIRECT_URL   → Same as DATABASE_URL (no pooler in Docker)
#
# Example Supabase URLs:
#   DATABASE_URL=postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5
#   DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=
DIRECT_URL=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Option A: Connection string
REDIS_URL=redis://localhost:6379
# Option B: Component-based (used by some Redis clients)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# MinIO (Object Storage)
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=derlg-storage

# ---------------------------------------------------------------------------
# Auth (JWT)
# ---------------------------------------------------------------------------
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# AI Service
# ---------------------------------------------------------------------------
AI_SERVICE_KEY=

# ---------------------------------------------------------------------------
# External Services (Optional for Phase 0)
# ---------------------------------------------------------------------------
# Resend API key for transactional email
RESEND_API_KEY=
# Firebase Cloud Messaging server key
FCM_SERVER_KEY=
# ExchangeRate-API key
EXCHANGE_RATE_API_KEY=
